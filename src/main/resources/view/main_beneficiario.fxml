<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import java.lang.String?>

<AnchorPane style="-fx-background-color: #f4f6f8;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pe.edu.upeu.controller.BeneficiarioController">
    <children>
        <VBox AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0" spacing="15.0">
            <children>

                <HBox style="-fx-background-color: #1a3a6c; -fx-background-radius: 5; -fx-padding: 10 15 10 15;">
                    <Label text="🏛 PADRÓN DE BENEFICIARIOS" textFill="WHITE">
                        <font><Font name="System Bold" size="20.0" /></font>
                    </Label>
                </HBox>

                <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                    <children>

                        <GridPane hgap="10" vgap="15" style="-fx-background-color: white; -fx-border-color: #cfd8dc; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 20;">
                            <columnConstraints>
                                <ColumnConstraints minWidth="90.0" />
                                <ColumnConstraints minWidth="180.0" />
                            </columnConstraints>
                            <children>

                                <Label text="DNI:" GridPane.rowIndex="0">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Label>
                                <TextField fx:id="txtDni" promptText="Ej: 72154896" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                <Label text="Folio:" GridPane.rowIndex="1">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Label>
                                <TextField fx:id="txtFolio" promptText="BEN-2026-001" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label text="Nombre:" GridPane.rowIndex="2">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Label>
                                <TextField fx:id="txtNombre" promptText="Apellidos y Nombres" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                <Label text="Programa:" GridPane.rowIndex="3">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Label>
                                <ComboBox fx:id="cmbPrograma" promptText="Seleccione programa..." prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                <Label text="Monto/Mes:" GridPane.rowIndex="4">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Label>
                                <TextField fx:id="txtMonto" promptText="Ej: 250.00" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                                <Label text="Fecha Alta:" GridPane.rowIndex="5">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                </Label>
                                <DatePicker fx:id="dpFechaAlta" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                                <HBox spacing="8" GridPane.columnSpan="2" GridPane.rowIndex="6" alignment="CENTER">
                                    <children>
                                        <Button fx:id="btnGuardar" text="💾 Guardar">
                                            <styleClass><String fx:value="btn"/><String fx:value="btn-success"/></styleClass>
                                        </Button>
                                        <Button fx:id="btnActualizar" text="✏️ Actualizar">
                                            <styleClass><String fx:value="btn"/><String fx:value="btn-primary"/></styleClass>
                                        </Button>
                                        <Button fx:id="btnLimpiar" text="🧹 Limpiar">
                                            <styleClass><String fx:value="btn"/><String fx:value="btn-default"/></styleClass>
                                        </Button>
                                        <Button fx:id="btnEliminar" text="🗑️ Eliminar">
                                            <styleClass><String fx:value="btn"/><String fx:value="btn-danger"/></styleClass>
                                        </Button>
                                    </children>
                                    <GridPane.margin><Insets top="15.0" /></GridPane.margin>
                                </HBox>
                            </children>
                        </GridPane>

                        <TableView fx:id="regBeneficiarioTabla" HBox.hgrow="ALWAYS" style="-fx-border-color: #cfd8dc; -fx-background-color: white;">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
